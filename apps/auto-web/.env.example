# AgentKitAuto (auto.agentkitproject.com) — standalone Next.js app.
#
# All values are read at RUNTIME (nothing is baked at build). Copy to
# .env.local for local dev. The build (next build) succeeds with NONE of these
# set — middleware + auth degrade gracefully — but the app only FUNCTIONS at
# runtime with WorkOS + a kit store + the Auto DynamoDB tables configured.
#
# ─────────────────────────────────────────────────────────────────────────────
# App URL / WorkOS redirect (runtime-resolved)
# ─────────────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# ─────────────────────────────────────────────────────────────────────────────
# WorkOS / AuthKit — browser cookie sessions (the Auto dashboard gate) AND the
# JWKS used to verify device-auth bearer tokens on /api/forge/auto/*.
# ─────────────────────────────────────────────────────────────────────────────
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
# Device-flow client id (bearer-token JWKS for /api/forge/auto/*). Falls back to
# WORKOS_CLIENT_ID when unset.
AGENTKITPROJECT_WORKOS_CLIENT_ID=
# Optional cookie name override (must match across SSO apps if sharing a domain).
# WORKOS_COOKIE_NAME=wos-session
# Optional WorkOS API endpoint overrides (testing only).
# WORKOS_API_HOSTNAME=api.workos.com
# WORKOS_API_HTTPS=true
# WORKOS_API_PORT=

# ─────────────────────────────────────────────────────────────────────────────
# AUTH PROVIDER (pluggable) — SELF-HOST.
# Selects the browser auth backend. Default (unset/"workos") = WorkOS/AuthKit
# (the hosted SaaS path above; behavior is unchanged). "oidc" = generic OpenID
# Connect (Authorization Code + PKCE, iron-session sealed cookie) for a
# self-hosted instance behind your own IdP (Keycloak, Dex, Authentik, Okta, …).
# AUTH_PROVIDER=oidc
#
# Required when AUTH_PROVIDER=oidc:
# OIDC_ISSUER=https://idp.example.com/realms/agentkit
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# Optional (defaults shown / derived):
# OIDC_SCOPES=openid profile email
# OIDC_REDIRECT_URI=  # defaults to {APP_URL}/auth/callback
# OIDC_ALLOW_INSECURE=  # "true" allows http issuers (dev/self-signed only)
# OIDC_SESSION_COOKIE=akf-oidc-session
# Path to land on after sign-in (Auto's dashboard is at "/").
# AUTH_POST_LOGIN_PATH=/
# Sealed-cookie secret (>=32 chars). Falls back to WORKOS_COOKIE_PASSWORD.
# SESSION_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# SELF-HOST + ECOSYSTEM ISOLATION.
# SELF_HOST=true is an explicit self-host signal (AUTH_PROVIDER=oidc implies it).
# Under self-host the app FAILS CLOSED on ecosystem couplings: it never phones
# home to the hosted Market, managed prepaid-credit billing is off (BYO key), and
# ecosystem links are only shown when explicitly configured below.
# SELF_HOST=true
# Force Market integration off entirely (even on hosted).
# DISABLE_MARKET=true
# Self-host ecosystem links (omitted from the UI when unset). The Market link
# follows AGENTKITMARKET_BASE_URL (your own Market) when set.
# NEXT_PUBLIC_PROJECT_URL=
# NEXT_PUBLIC_FORGE_URL=
# NEXT_PUBLIC_PROFILE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Kit store — backs GET /api/kits (Auto's kit selector) and server-side kit
# resolution at run time. "local" (DynamoDB-backed on AWS / local disk in dev),
# "aws", or "selfhost" (Postgres).
# ─────────────────────────────────────────────────────────────────────────────
KITSTORE_BACKEND=local
# Local-disk dev data dir (KITSTORE_BACKEND=local without AWS creds).
# AGENTKITFORGE_WEB_DATA_DIR=.agentkitauto-app-data
# Secret used to encrypt stored per-user provider keys.
# AGENTKITFORGE_WEB_SECRET=
# selfhost (Postgres) connection string.
# DATABASE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Auto DynamoDB tables (names; created/owned by agentkit infra). Defaults shown.
# ─────────────────────────────────────────────────────────────────────────────
AUTO_RUNS_TABLE=AutoRuns
AUTO_APPROVALS_TABLE=AutoApprovals
AUTO_SCHEDULES_TABLE=AutoSchedules
AUTO_WEBHOOKS_TABLE=AutoWebhooks

# ─────────────────────────────────────────────────────────────────────────────
# AWS (DynamoDB + S3). Use FORGE_AWS_* or an IAM role.
# ─────────────────────────────────────────────────────────────────────────────
FORGE_AWS_REGION=us-east-1
# AWS_REGION=us-east-1
FORGE_AWS_ACCESS_KEY_ID=
FORGE_AWS_SECRET_ACCESS_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Auto input files (presigned-upload staging). Falls back to S3_BUCKET/S3_PREFIX.
# ─────────────────────────────────────────────────────────────────────────────
AUTO_INPUTS_BUCKET=
# S3_BUCKET=
# S3_PREFIX=

# ─────────────────────────────────────────────────────────────────────────────
# Run dispatch. Unset = in-process (dev). "fargate" = hosted ECS worker.
# "k8s" = self-host Kubernetes Job worker.
# ─────────────────────────────────────────────────────────────────────────────
# AUTO_DISPATCH=
# Internal worker auth — required when running with a hosted/self-host worker;
# guards /api/internal/auto/* (resolve-context + sweep). Unset = those routes 503.
AUTO_WORKER_SERVICE_KEY=
# Fargate dispatcher (AUTO_DISPATCH=fargate):
# AUTO_ECS_CLUSTER=
# AUTO_ECS_TASK_DEF=
# AUTO_ECS_SUBNET_IDS=
# AUTO_ECS_SECURITY_GROUP_ID=
# AUTO_ECS_CONTAINER_NAME=auto-worker
# Kubernetes dispatcher (AUTO_DISPATCH=k8s):
# AUTO_K8S_WORKER_IMAGE=
# AUTO_K8S_NAMESPACE=default
# AUTO_K8S_SERVICE_ACCOUNT=
# AUTO_K8S_CPU_REQUEST=500m
# AUTO_K8S_CPU_LIMIT=2
# AUTO_K8S_MEMORY_REQUEST=512Mi
# AUTO_K8S_MEMORY_LIMIT=4Gi
# AUTO_K8S_TTL_SECONDS=86400
# AUTO_K8S_BACKOFF_LIMIT=3
# AUTO_K8S_SCRATCH_SIZE=10Gi
# AUTO_K8S_RUN_AS_USER=1000

# ─────────────────────────────────────────────────────────────────────────────
# Billing (managed inference markup + per-minute compute fee).
# HOSTED only — managed prepaid-credit billing against the DynamoDB ledger.
# ─────────────────────────────────────────────────────────────────────────────
# AUTO_MARKUP_BPS=    (basis points; 0 by default, set server-side)
# AUTO_CLOUD_RUN_CENTS_PER_MIN=    (cents/min; 0 by default, set server-side)
# GATEWAY_MARKUP_BPS=
# SELF-HOST billing policy. Default "free": every run is BYO against the
# operator's ANTHROPIC_API_KEY, NO credit ledger (auto-core's inert free ledger).
# "managed": metered billing via the selfhost Postgres ledger (k8s worker only).
# AUTO_SELFHOST_BILLING=free

# ─────────────────────────────────────────────────────────────────────────────
# LLM + protected Market kits.
# ANTHROPIC_API_KEY is the PLATFORM key on hosted, and the operator's BYO key on
# self-host (the only inference path there). AGENTKITMARKET_BASE_URL points at a
# Market: on hosted it defaults to the public Market; on self-host it must be your
# OWN Market (unset ⇒ Market disabled, never a hosted fallback).
# ─────────────────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=
# AGENTKITMARKET_BASE_URL=
# MARKET_SERVICE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Quota overrides (optional).
# ─────────────────────────────────────────────────────────────────────────────
# FORGE_MAX_KITS_PER_ACCOUNT=
# FORGE_MAX_BYTES_PER_ACCOUNT=
# FORGE_MAX_BYTES_PER_FILE=
