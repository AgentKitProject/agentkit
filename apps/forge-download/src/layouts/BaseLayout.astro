---
import '@agentkitforge/ui/styles.css';
import { navWithActive, DEFAULT_FOOTER_LINKS } from '@agentkitforge/ui';
import Logo from '../components/Logo.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'AgentKitForge helps teams build, validate, package, install, and run reusable Agent Kits for AI workflows.'
} = Astro.props;

const pageTitle = title === 'AgentKitForge' ? title : `${title} | AgentKitForge`;
const currentPath = Astro.url.pathname;

// Canonical ecosystem nav (Forge tab marked active on the download/release site).
// Cross-product destinations (Home, Web Forge, Auto, Market, Docs, Roadmap,
// Account) come from the shared set so they stay consistent across all apps.
const canonicalNav = navWithActive('Forge');

// Forge-site-specific links the download/release site must keep. These point at
// local pages on forge.agentkitproject.com and are appended after the canonical
// items (the canonical "Docs" points at the ecosystem docs; "App / CLI / Download
// / Contribute" are the Forge product pages and are load-bearing here).
const forgeLocalNav = [
  { label: 'App', href: '/app/' },
  { label: 'CLI', href: '/cli/' },
  { label: 'Download', href: '/download/' },
  { label: 'Contribute', href: '/contribute/' }
];
const isLocalActive = (href: string) =>
  href.startsWith('/') && (href === '/' ? currentPath === '/' : currentPath.startsWith(href));

const footer = DEFAULT_FOOTER_LINKS;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/brand/agentkitforge-icon.svg" />
    <title>{pageTitle}</title>
    <link rel="canonical" href={new URL(Astro.url.pathname, 'https://forge.agentkitproject.com').href} />
    <link rel="icon" type="image/png" href="/brand/agentkitforge-icon.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/brand/agentkitforge-icon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={new URL(Astro.url.pathname, 'https://forge.agentkitproject.com').href} />
    <meta property="og:image" content="https://forge.agentkitproject.com/brand/agentkitforge-og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://forge.agentkitproject.com/brand/agentkitforge-og.png" />
  </head>
  <body class="ak-root ak-shell theme-forge">
    <a href="#main-content" class="ak-skip-link">Skip to content</a>
    <header class="ak-header site-header">
      <div class="ak-header__inner">
        <span class="ak-header__logo"><Logo /></span>
        <nav class="ak-header__nav" aria-label="Primary navigation">
          {canonicalNav.map((item) => (
            <a
              class={`ak-header__nav-link${item.active ? ' ak-header__nav-link--active' : ''}`}
              href={item.href}
              aria-current={item.active ? 'page' : undefined}
              target={item.external ? '_blank' : undefined}
              rel={item.external ? 'noreferrer noopener' : undefined}
            >{item.label}</a>
          ))}
          {forgeLocalNav.map((item) => (
            <a
              class={`ak-header__nav-link${isLocalActive(item.href) ? ' ak-header__nav-link--active' : ''}`}
              href={item.href}
              aria-current={isLocalActive(item.href) ? 'page' : undefined}
            >{item.label}</a>
          ))}
        </nav>
        <span class="ak-header__spacer"></span>
        <span class="ak-header__account">
          <a id="ak-account" class="ak-btn ak-btn--secondary ak-btn--sm" href="https://profile.agentkitproject.com">Account</a>
          <a class="ak-btn ak-btn--secondary ak-btn--sm nav-github" href="https://github.com/AgentKitProject">GitHub</a>
        </span>
      </div>
    </header>
    <script is:inline>
      // Cross-site login indicator: reflect AgentKitProfile session via the
      // shared WorkOS cookie. Dependency-free, never blocks render, never
      // errors visibly. Degrades to a "Sign in" link on any failure.
      (function () {
        var el = document.getElementById('ak-account');
        if (!el) return;
        var PROFILE = 'https://profile.agentkitproject.com';
        function setSignedOut() {
          el.textContent = 'Sign in';
          el.setAttribute('href', PROFILE);
        }
        try {
          fetch(PROFILE + '/api/me', { credentials: 'include' })
            .then(function (r) { return r.ok ? r.json() : null; })
            .then(function (d) {
              if (d && d.signedIn) {
                el.textContent = d.displayName || d.avatarInitials || 'Account';
                el.setAttribute('href', PROFILE);
              } else {
                setSignedOut();
              }
            })
            .catch(setSignedOut);
        } catch (e) {
          setSignedOut();
        }
      })();
    </script>
    <main id="main-content" class="ak-main">
      <slot />
    </main>
    <footer class="ak-footer site-footer">
      <div class="ak-footer__inner">
        <div>
          <p class="ak-footer__brand-title">AgentKitForge</p>
          <p class="ak-footer__brand-subtitle">Open ecosystem for portable, reusable Agent Kits.</p>
          <p style="margin-top:12px">
            <a class="ak-footer__contact" href={`mailto:${footer.contactEmail}`}>{footer.contactEmail}</a>
          </p>
        </div>
        <div>
          <p class="ak-footer__col-title">Ecosystem</p>
          <ul class="ak-footer__links">
            {footer.ecosystem.map((link) => (
              <li>
                <a
                  class="ak-footer__link"
                  href={link.href}
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noreferrer noopener' : undefined}
                >{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <p class="ak-footer__col-title">Legal</p>
          <ul class="ak-footer__links">
            {footer.legal.map((link) => (
              <li><a class="ak-footer__link" href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
      <div class="ak-footer__bottom">
        <span>&copy; 2026 AgentKitProject</span>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    /* Forge brand source colors (site-owned). */
    --forge: #5b4cf0;
    --accent-cyan: #06b6d4;

    /* ----- Bridge: @agentkitforge/ui --ak-* tokens -----
       Drive the shared ak- chrome (header/footer/buttons/cards) in the Forge
       palette so the download/release site coheres with the rest of the
       ecosystem. The body carries `theme-forge` for the framework brand accent. */
    --ak-brand: var(--forge);
    --ak-brand-strong: #4338ca;
    --ak-brand-soft: #eef2ff;
    --ak-accent: var(--accent-cyan);
    --ak-text: #0f172a;
    --ak-muted: #475569;
    --ak-bg: #f8fafc;
    --ak-surface: #ffffff;
    --ak-surface-muted: #f1f5f9;
    --ak-border: #cbd5e1;
    --ak-success: #16a34a;
    --ak-warning: #d97706;
    --ak-error: #dc2626;

    /* ----- Bridge: site vars -> shared --ak-* tokens (minimal markup churn) ----- */
    --primary: var(--ak-brand);
    --primary-hover: var(--ak-brand-strong);
    --accent: var(--ak-accent);
    --success: var(--ak-success);
    --warning: var(--ak-warning);
    --error: var(--ak-error);
    --text: var(--ak-text);
    --muted: var(--ak-muted);
    --background: var(--ak-bg);
    --surface: var(--ak-surface);
    --muted-surface: var(--ak-surface-muted);
    --border: var(--ak-border);
    --code: #eef2ff;
    --shadow: var(--ak-shadow, 0 14px 40px rgba(15, 23, 42, 0.07));
  }

  /* Forge brand accent for the framework header/footer/buttons. */
  body.theme-forge {
    --ak-brand: var(--forge);
    --ak-brand-strong: #4338ca;
    --ak-brand-soft: #eef2ff;
  }

  * {
    box-sizing: border-box;
  }

  * {
    min-width: 0;
  }

  html {
    background: var(--background);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
    scroll-behavior: smooth;
  }

  body {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), transparent 18rem),
      radial-gradient(circle at top left, rgba(79, 70, 229, 0.07), transparent 24rem),
      radial-gradient(circle at top right, rgba(6, 182, 212, 0.08), transparent 22rem),
      var(--background);
    color: var(--text);
    margin: 0;
    min-width: 320px;
    overflow-x: clip;
  }

  a {
    color: var(--primary);
  }

  img,
  svg {
    max-width: 100%;
  }

  .container {
    margin: 0 auto;
    max-width: 1120px;
    padding: 0 1.25rem;
    width: 100%;
  }

  /* Header chrome uses the shared .ak-header classes; keep the nav visible and
     wrapping (no JS hamburger), since the Forge site carries extra product links. */
  .ak-header.site-header {
    position: sticky;
    top: 0;
    z-index: 20;
  }

  .ak-header__inner {
    min-height: 4.5rem;
    flex-wrap: wrap;
  }

  @media (max-width: 860px) {
    .ak-header__nav {
      display: flex;
      flex-wrap: wrap;
    }
    .ak-header__spacer {
      display: none;
    }
  }

  .section {
    padding: 4.5rem 0;
  }

  .section.tight {
    padding: 2.75rem 0;
  }

  .eyebrow {
    color: var(--primary);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    margin: 0 0 0.85rem;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    color: var(--text);
    letter-spacing: 0;
    line-height: 1.08;
    margin: 0;
  }

  h1 {
    font-size: clamp(2.6rem, 8vw, 5rem);
    max-width: 900px;
  }

  h2 {
    font-size: clamp(1.8rem, 4vw, 3rem);
  }

  h3 {
    font-size: 1.25rem;
  }

  p {
    color: var(--muted);
    line-height: 1.7;
    overflow-wrap: normal;
  }

  .lead {
    font-size: clamp(1.08rem, 2vw, 1.35rem);
    max-width: 820px;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }

  .button {
    align-items: center;
    background: var(--primary);
    border: 1px solid var(--primary);
    border-radius: 12px;
    color: white;
    display: inline-flex;
    font-weight: 800;
    justify-content: center;
    min-height: 2.9rem;
    padding: 0.75rem 1rem;
    text-decoration: none;
    transition:
      background-color 140ms ease,
      border-color 140ms ease,
      box-shadow 140ms ease,
      transform 140ms ease;
  }

  .button.secondary {
    background: var(--surface);
    border-color: var(--border);
    color: var(--text);
  }

  .button:hover,
  .button:focus-visible {
    background: var(--primary-hover);
    border-color: var(--primary-hover);
    box-shadow: 0 10px 22px rgba(79, 70, 229, 0.18);
    color: white;
    outline: none;
    transform: translateY(-1px);
  }

  .button.secondary:hover,
  .button.secondary:focus-visible {
    background: var(--muted-surface);
    border-color: color-mix(in srgb, var(--primary) 35%, var(--border));
    color: var(--text);
  }

  .grid {
    display: grid;
    gap: 1rem;
  }

  .grid.two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .grid.three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .grid.four {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow: var(--shadow);
    padding: 1.25rem;
    transition:
      border-color 140ms ease,
      box-shadow 140ms ease,
      transform 140ms ease;
  }

  .card:hover {
    border-color: color-mix(in srgb, var(--primary) 28%, var(--border));
    box-shadow: 0 18px 46px rgba(15, 23, 42, 0.1);
    transform: translateY(-2px);
  }

  .card p:last-child,
  .content-panel p:last-child {
    margin-bottom: 0;
  }

  .content-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: clamp(1.25rem, 4vw, 2.25rem);
  }

  .badge {
    align-items: center;
    border: 1px solid transparent;
    border-radius: 999px;
    display: inline-flex;
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1;
    padding: 0.42rem 0.65rem;
  }

  .badge.valid {
    background: color-mix(in srgb, var(--success) 12%, transparent);
    border-color: color-mix(in srgb, var(--success) 35%, transparent);
    color: var(--success);
  }

  .badge.publishable {
    background: color-mix(in srgb, var(--primary) 12%, transparent);
    border-color: color-mix(in srgb, var(--primary) 35%, transparent);
    color: var(--primary);
  }

  .badge.trusted {
    background: color-mix(in srgb, #7c3aed 12%, transparent);
    border-color: color-mix(in srgb, #7c3aed 35%, transparent);
    color: #7c3aed;
  }

  .badge.verified {
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border-color: color-mix(in srgb, var(--accent) 35%, transparent);
    color: var(--accent);
  }

  .badge.warning {
    background: color-mix(in srgb, var(--warning) 12%, transparent);
    border-color: color-mix(in srgb, var(--warning) 35%, transparent);
    color: var(--warning);
  }

  code {
    background: var(--code);
    border-radius: 7px;
    color: var(--text);
    font-size: 0.92em;
    overflow-wrap: anywhere;
    padding: 0.15rem 0.35rem;
    word-break: break-word;
  }

  pre {
    background: #0f172a;
    border-radius: 12px;
    color: #e2e8f0;
    max-width: 100%;
    overflow-x: auto;
    padding: 1rem;
  }

  pre code {
    background: transparent;
    color: inherit;
    overflow-wrap: normal;
    padding: 0;
    word-break: normal;
  }

  :focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 3px;
  }

  @media (max-width: 860px) {
    .grid.two,
    .grid.three,
    .grid.four {
      grid-template-columns: 1fr;
    }
  }
</style>
