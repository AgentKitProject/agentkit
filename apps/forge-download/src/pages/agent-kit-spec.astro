---
import BaseLayout from '../layouts/BaseLayout.astro';

const files = [
  'agentkit.yaml',
  'AGENTKIT.md',
  'START_HERE.md',
  'README.md',
  'LICENSE',
  'CHANGELOG.md',
  'prompts/',
  'skills/<skill-id>/SKILL.md',
  'workflows/',
  'policies/',
  'references/',
  'templates/',
  'examples/',
  'evals/',
  'adapters/',
  'scripts/',
  'assets/',
  'exports/'
];

const requiredFiles = ['agentkit.yaml', 'AGENTKIT.md'];
const optionalSections = [
  'START_HERE.md',
  'README.md',
  'LICENSE',
  'CHANGELOG.md',
  'prompts/',
  'skills/',
  'policies/',
  'templates/',
  'examples/',
  'evals/',
  'adapters/',
  'scripts/',
  'assets/',
  'exports/'
];

const levels = [
  ['local-valid', 'valid', 'The package is structurally valid and usable in a local workspace.'],
  ['publishable', 'publishable', 'The kit has metadata, documentation, licensing, and validation needed for public distribution.'],
  ['trusted', 'trusted', 'The kit has stronger provenance, review, and policy checks for safer reuse.'],
  ['verified', 'verified', 'The kit has completed the highest available validation and publisher verification path.']
];
---
<BaseLayout title="Agent Kit Spec">
  <section class="section">
    <div class="container">
      <p class="eyebrow">Specification</p>
      <h1>Agent Kit package structure</h1>
      <p class="lead">
        AgentKitForge treats an Agent Kit as a canonical, portable directory that can be validated,
        packaged, installed into supported agent tools, and exported for web-assistant workflows.
      </p>
      <p class="beginner-bridge">
        New to Agent Kits? Start with the beginner guide:
        <a href="/docs/what-is-an-agent-kit/">What is an Agent Kit?</a>
      </p>
      <div class="grid two spec-grid">
        <section class="content-panel">
          <h2>Canonical files</h2>
          <ul class="file-list">
            {files.map((file) => <li><code>{file}</code></li>)}
          </ul>
        </section>
        <section class="content-panel">
          <h2>Validation levels</h2>
          <div class="level-list">
            {levels.map(([name, badge, body]) => (
              <article>
                <span class={`badge ${badge}`}>{name}</span>
                <p>{body}</p>
              </article>
            ))}
          </div>
        </section>
      </div>
      <div class="grid three spec-grid">
        <section class="content-panel">
          <h2>Required files</h2>
          <ul>
            {requiredFiles.map((file) => <li><code>{file}</code></li>)}
          </ul>
          <p>
            Required files identify the package and provide the main agent-facing instructions.
          </p>
        </section>
        <section class="content-panel">
          <h2>Optional sections</h2>
          <ul>
            {optionalSections.map((file) => <li><code>{file}</code></li>)}
          </ul>
        </section>
        <section class="content-panel">
          <h2>Artifacts</h2>
          <p>
            Common generated artifacts include <code>.agentkit.zip</code> packages, one-file
            Markdown exports, local agent install outputs, rendered prepared prompts, and generated
            document-like run outputs.
          </p>
        </section>
      </div>
      <div class="content-panel spec-grid">
        <h2>Prepared prompts</h2>
        <p>
          Prepared prompts define reusable prompt flows, required inputs, preview text, output
          expectations, and optional templates. Forge can collect required inputs before running a
          prompt and can render outputs for download.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .spec-grid {
    align-items: start;
    margin-top: 2rem;
  }

  .beginner-bridge {
    background: var(--muted-surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    color: var(--text);
    font-weight: 750;
    margin-top: 1.25rem;
    max-width: 820px;
    padding: 0.9rem 1rem;
  }

  .beginner-bridge a {
    font-weight: 900;
    text-decoration: none;
  }

  .file-list {
    columns: 2;
    line-height: 2;
    padding-left: 1.15rem;
  }

  .level-list {
    display: grid;
    gap: 1rem;
  }

  .level-list article {
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }

  .level-list p {
    margin: 0.75rem 0 0;
  }

  @media (max-width: 640px) {
    .file-list {
      columns: 1;
    }
  }
</style>
