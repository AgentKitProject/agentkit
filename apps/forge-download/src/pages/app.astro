---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  ['Build with AI', 'Start from a plain-language prompt, iterate on draft sessions, request changes, and save when the kit is ready.'],
  ['Guided Builder', 'Use structured forms for purpose, required inputs, prepared prompts, output style, templates, and validation goals.'],
  ['Edit with AI / Guided Editor', 'Refine existing kits with AI-assisted edits or controlled form-based updates.'],
  ['Prepared Prompts', 'Define reusable prompts with required inputs, prompt preview, and document-like outputs.'],
  ['Use inside Forge', 'Fill required inputs, add context, preview the planned prompt, run with your provider, and download output.'],
  ['Import kits', 'Import from .agentkit.zip, a local folder, or a Git repository using your local Git credentials.'],
  ['Package / Export', 'Create .agentkit.zip packages, one-file Markdown bundles, and local agent exports.'],
  ['Install on Local Agent', 'Install Agent Kits into supported local agent tools like Codex and Claude Code.'],
  ['AI providers', 'Use OpenAI, Anthropic Claude, Google Gemini, Ollama, or custom OpenAI-compatible endpoints.'],
  ['Local-first', 'Build and use kits from the desktop app without requiring an AgentKitForge account.']
];
---
<BaseLayout title="App">
  <section class="section hero">
    <div class="container app-hero">
      <div>
        <p class="eyebrow">Desktop app</p>
        <h1>Build, edit, use, package, and install Agent Kits in one interface.</h1>
        <p class="lead">
          AgentKitForge is the desktop app for building and using Agent Kits. An Agent Kit is a
          reusable package of prompts, skills, policies, templates, examples, and context for a
          specific AI workflow.
        </p>
        <div class="button-row">
          <a class="button" href="/download/">Download AgentKitForge</a>
          <a class="button secondary" href="/docs/">Read the docs</a>
        </div>
      </div>
      <div class="app-window">
        <div class="window-top"><span></span><span></span><span></span><strong>Use inside Forge</strong></div>
        <div class="split">
          <div class="sidebar">
            <b>Prepared Prompt</b>
            <span>Research brief</span>
            <span>Inputs required</span>
            <span>Provider: Gemini</span>
          </div>
          <div class="main-pane">
            <label>Client notes</label>
            <div class="input-line"></div>
            <label>Audience</label>
            <div class="input-line short"></div>
            <div class="preview">Prompt preview ready</div>
            <button type="button">Run and generate output</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="container">
      <p class="eyebrow">Overview</p>
      <h2>Designed for people who want reusable AI workflows without wiring tools together.</h2>
      <div class="grid two feature-grid">
        {sections.map(([title, body]) => (
          <article class="card">
            <h3>{title}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Screens</p>
      <h2>App screens at a glance</h2>
      <div class="mock-grid">
        <article class="mock-screen ai"><h3>Build with AI</h3><p>Draft session with requested changes.</p></article>
        <article class="mock-screen form"><h3>Guided Builder</h3><p>Purpose, inputs, outputs, templates.</p></article>
        <article class="mock-screen use"><h3>Use with inputs</h3><p>Required fields collected before run.</p></article>
        <article class="mock-screen output"><h3>Output panel</h3><p>Download Markdown / Text.</p></article>
        <article class="mock-screen package"><h3>Package / Export</h3><p>.agentkit.zip, one-file, Codex, Claude Code.</p></article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: clamp(4rem, 10vh, 7rem);
  }

  .app-hero {
    align-items: center;
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 0.9fr);
  }

  .app-window,
  .mock-screen {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    box-shadow: var(--shadow);
  }

  .app-window {
    padding: 1rem;
  }

  .window-top {
    align-items: center;
    border-bottom: 1px solid var(--border);
    display: flex;
    gap: 0.45rem;
    padding-bottom: 0.85rem;
  }

  .window-top span {
    background: var(--border);
    border-radius: 999px;
    height: 0.65rem;
    width: 0.65rem;
  }

  .window-top strong {
    color: var(--text);
    margin-left: 0.5rem;
  }

  .split {
    display: grid;
    gap: 1rem;
    grid-template-columns: 0.8fr 1.2fr;
    padding-top: 1rem;
  }

  .sidebar,
  .main-pane {
    background: var(--muted-surface);
    border-radius: 14px;
    padding: 1rem;
  }

  .sidebar span,
  .sidebar b,
  .main-pane label {
    display: block;
  }

  .sidebar b,
  .main-pane label {
    color: var(--text);
    font-weight: 850;
    margin-bottom: 0.65rem;
  }

  .sidebar span {
    color: var(--muted);
    margin-top: 0.6rem;
  }

  .input-line,
  .preview {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    margin-bottom: 0.9rem;
  }

  .input-line {
    height: 2.2rem;
  }

  .input-line.short {
    width: 70%;
  }

  .preview {
    color: var(--primary);
    font-weight: 850;
    padding: 0.85rem;
  }

  button {
    background: var(--primary);
    border: 0;
    border-radius: 10px;
    color: white;
    font: inherit;
    font-weight: 850;
    padding: 0.75rem 0.9rem;
  }

  .feature-grid,
  .mock-grid {
    margin-top: 1.5rem;
  }

  .mock-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .mock-screen {
    min-height: 13rem;
    overflow: hidden;
    padding: 1rem;
    position: relative;
  }

  .mock-screen::after {
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    border-radius: 999px;
    content: "";
    height: 7rem;
    position: absolute;
    right: -2rem;
    top: 4rem;
    width: 7rem;
  }

  .mock-screen h3,
  .mock-screen p {
    position: relative;
    z-index: 1;
  }

  @media (max-width: 1080px) {
    .mock-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 920px) {
    .app-hero,
    .split {
      grid-template-columns: 1fr;
    }
  }
</style>
