---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Agent Kit Market">
  <section class="section">
    <div class="container">
      <img class="market-logo" src="/brand/agentkitmarket-logo.svg" alt="Agent Kit Market" />
      <p class="eyebrow">Preview</p>
      <h1>AgentKit Market</h1>
      <p class="lead">
        Agent Kit Market will be the marketplace and repository for Agent Kits after the builder,
        packaging, validation, and distribution foundation is stable.
      </p>
      <div class="button-row">
        <a class="button" href="https://market.agentkitproject.com">Browse AgentKit Market</a>
      </div>
      <div class="grid two market-grid">
        <article class="content-panel">
          <h2>Forge builds kits.</h2>
          <p>
            AgentKitForge is the local builder for creating, validating, packaging, importing, and
            exporting reusable Agent Kits with OpenAI, Claude, Gemini, Ollama, or custom compatible
            providers.
          </p>
        </article>
        <article class="content-panel">
          <h2>Market distributes kits.</h2>
          <p>
            Agent Kit Market will later provide public marketplace discovery plus private
            organization repositories for storing and distributing kits independent of provider
            choice.
          </p>
        </article>
      </div>
      <p class="scope-note">
        No marketplace functionality is implemented here. Accounts, listings, payments, private
        storage, and product backend services belong in separate repos.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .market-logo {
    height: 2.8rem;
    margin-bottom: 1rem;
    width: auto;
  }

  .market-grid {
    margin-top: 2rem;
  }

  .scope-note {
    background: var(--muted-surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    margin-top: 1rem;
    padding: 1rem;
  }
</style>
