---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Privacy Policy"
  description="AgentKitForge Privacy Policy."
>
  <section class="section">
    <div class="container">
      <div class="template-notice">
        <strong>Template — not legal advice.</strong> This is a placeholder template. Review with qualified legal counsel before publishing.
      </div>
      <p class="eyebrow">Legal</p>
      <h1>Privacy Policy</h1>
      <p class="lead">Last updated: June 2026. This page covers the AgentKitForge download site (forge.agentkitproject.com). For the full ecosystem privacy policy, see <a href="https://agentkitproject.com/privacy">agentkitproject.com/privacy</a>.</p>
    </div>
  </section>
</BaseLayout>

<style>
  .template-notice {
    background: #fef9c3;
    border: 1px solid #fde047;
    border-radius: 8px;
    margin-bottom: 2rem;
    padding: 1rem 1.25rem;
    color: #713f12;
  }
</style>
