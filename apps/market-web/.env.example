# Client-safe public API URL. This is visible in the browser bundle.
NEXT_PUBLIC_AGENTKITMARKET_API_BASE_URL=https://u8u5r1puai.execute-api.us-east-1.amazonaws.com/v0

# Client-safe development flag. Do not enable in production.
NEXT_PUBLIC_AGENTKITMARKET_USE_MOCKS=false

# Server-only admin/service key for backend ingestion, review, publish, and download URL calls.
# Do not prefix secrets with NEXT_PUBLIC_.
AGENTKITMARKET_ADMIN_KEY=

# Server-only service key for the web-forge → market-app service-to-service
# licensed-package endpoint (hosted AgentKitAuto protected-kit resolution).
# Set IDENTICALLY on BOTH market-app and agentkitforge. Constant-time
# compared; never log it; never prefix with NEXT_PUBLIC_. When unset, the
# /api/forge/service/* endpoint is DISABLED (503) — entitlement is still enforced
# when set (the asserted user must hold an active entitlement). Generate with
# `openssl rand -hex 32`.
MARKET_SERVICE_KEY=

# Server-side AgentKitProfile API integration for safe public publisher snapshots.
# Must point at the Profile API Gateway (agentkitprofile-infra), which serves
# GET /profiles/{userId}. The profile web app (profile.agentkitproject.com) does
# NOT expose that route, so do not point this at the web app.
# Do not prefix PROFILE_SERVICE_KEY with NEXT_PUBLIC_.
PROFILE_API_BASE_URL=https://glz766c120.execute-api.us-east-1.amazonaws.com/prod
PROFILE_SERVICE_KEY=

# ---------------------------------------------------------------------------
# Pluggable authentication backend (server-only).
#
# AUTH_PROVIDER selects the auth backend for the Market WEB tier:
#   - unset | "workos" → WorkOS/AuthKit cookie sessions (HOSTED SaaS; default).
#   - "oidc"           → generic OpenID Connect (Auth Code + PKCE) for SELF-HOST.
#
# This selects ONLY the browser/cookie auth path (pages, /api/submissions/*,
# /api/kits/*, /api/admin/*). The Forge device-bearer path (/api/forge/*,
# requireForgeUser) is WorkOS-bound and becomes INERT (501) under oidc — it is
# not needed for a web-only self-hosted Market. Leave unset/"workos" for hosted.
AUTH_PROVIDER=workos
# ---------------------------------------------------------------------------

# WorkOS AuthKit server-side configuration and secrets (used by AUTH_PROVIDER=workos).
# Do not prefix WORKOS_API_KEY or WORKOS_COOKIE_PASSWORD with NEXT_PUBLIC_.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
# Hosted (WorkOS) admin allowlist: comma-separated emails granted the admin role.
AGENTKITMARKET_ADMIN_EMAILS=jag8765@gmail.com
AGENTKITMARKET_AUTH_DEBUG=false

# Generic OIDC configuration (used ONLY when AUTH_PROVIDER=oidc; self-hosted).
# Discovery is performed against {OIDC_ISSUER}/.well-known/openid-configuration.
# OIDC_SCOPES defaults to "openid profile email"; OIDC_REDIRECT_URI defaults to
# {APP_URL}/auth/callback. Register that redirect URI with your IdP.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# OIDC_SCOPES=openid profile email
# OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
# Set OIDC_ALLOW_INSECURE=true ONLY for local/dev IdPs served over plain http.
# OIDC_ALLOW_INSECURE=false
#
# OIDC session cookie secret (iron-session). Must be >= 32 chars. Falls back to
# WORKOS_COOKIE_PASSWORD when unset so a single secret can serve both providers.
# Generate with `openssl rand -hex 32`.
# SESSION_SECRET=
#
# OIDC admin gating (self-hosted): a user is an admin when EITHER the configured
# group appears in their OIDC `groups`/`roles` claim (ADMIN_OIDC_GROUP), OR their
# email is in ADMIN_EMAILS (falls back to AGENTKITMARKET_ADMIN_EMAILS when unset).
# Configure at least one so a self-host operator can reach /admin.
# ADMIN_OIDC_GROUP=market-admins
# ADMIN_EMAILS=admin@your-company.example

# Canonical app and WorkOS redirect URLs.
# APP_URL and WORKOS_REDIRECT_URI are server-side.
# NEXT_PUBLIC_APP_URL and NEXT_PUBLIC_WORKOS_REDIRECT_URI are client-safe copies of public origins/URLs.
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# Commercial layer (Stripe payments, pricing/entitlement/licensing, seller
# payouts) is OPTIONAL and lives in the private @agentkit-commercial/market-web
# package — NOT in this open-source app. Without that package installed, all
# payment/entitlement routes (/api/kits/[slug]/{checkout,pricing,acquire,
# licensed-package}, /api/stripe/webhook, /api/orgs/[orgId]/payouts/*, the
# /api/forge/* and /api/forge/service/* entitlement routes) are inert and return
# 503 { "error": "commerce_disabled" }, and the paid-kit UI is hidden.
#
# Set NEXT_PUBLIC_COMMERCE_ENABLED=1 only on a hosted build where the commercial
# package is installed; this gates re-introduction of the paid-kit client UI.
# The STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET / Stripe Connect env lives in the
# commercial package's own .env.example.
NEXT_PUBLIC_COMMERCE_ENABLED=

# Premium (per-invocation / run-on-Auto) kits ship DARK behind a kill-switch.
# Default OFF: the seller UI hides the "Premium (per run)" pricing option unless
# this is exactly "true". This is UX convenience only — the REAL gate is the
# server flag PREMIUM_KITS_ENABLED on the market-core backend, which rejects a
# per_invocation set-pricing while off. Set both true ONLY at the premium go-live.
NEXT_PUBLIC_PREMIUM_KITS_ENABLED=
