APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_WORKOS_REDIRECT_URI is not currently required.
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
AGENTKITPROJECT_ADMIN_EMAILS=
PROFILE_API_BASE_URL=
PROFILE_SERVICE_KEY=
# In-process Postgres-backed profile-api (Kubernetes deployment).
# PROFILE_API_BASE_URL should point at this pod's own service (self HTTP call).
DATABASE_URL=
# Backend selector; only "postgres" is implemented. Defaults to postgres.
PROFILE_STORE=postgres
# Set to "disable" to turn off TLS (e.g. local Postgres without SSL).
PROFILE_DB_SSL=
