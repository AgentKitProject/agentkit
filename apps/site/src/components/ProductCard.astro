---
interface Props {
  name: string;
  href: string;
  status: string;
  statusTone: 'live' | 'soon' | 'planned';
  accent: string;
  accentSoft: string;
  purpose: string;
  summary: string;
  icon?: string;
}

const { name, href, status, statusTone, accent, accentSoft, purpose, summary, icon } = Astro.props;
---
<article class="product-card" style={`--product-accent: ${accent}; --product-accent-soft: ${accentSoft};`}>
  {icon
    ? <img class="product-logo" src={icon} alt={`${name} logo`} width="38" height="38" />
    : <span class="product-glyph" aria-hidden="true"></span>
  }
  <div class="product-card-head">
    <h3>{name}</h3>
    <span class={`status ${statusTone}`}>{status}</span>
  </div>
  <p class="purpose">{purpose}</p>
  <p>{summary}</p>
  <a href={href} aria-label={`Explore ${name}`}>Explore {name}</a>
</article>

<style>
  .product-card {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--product-accent-soft) 70%, white), white 46%),
      var(--surface);
    border: 1px solid color-mix(in srgb, var(--product-accent) 26%, var(--border));
    border-radius: 8px;
    box-shadow: var(--shadow);
    display: flex;
    flex-direction: column;
    min-height: 100%;
    overflow: hidden;
    padding: 1.25rem;
    position: relative;
    transition:
      border-color 140ms ease,
      box-shadow 140ms ease,
      transform 140ms ease;
  }

  .product-card::before {
    background: var(--product-accent);
    content: "";
    height: 4px;
    inset: 0 0 auto;
    position: absolute;
  }

  /* Dark mode: the light gradient (ending in opaque white) stays light, but the
     card text uses --text, which flips to near-white in dark mode → title and
     subtitle render light-on-light (illegible). Flip the card to a dark, accent-
     tinted surface so the light text reads and the card matches the rest of the
     dark UI. The accent top stripe (::before) is unchanged. */
  :global(html[data-theme="dark"]) .product-card {
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--product-accent) 16%, var(--surface)),
        var(--surface) 52%
      ),
      var(--surface);
    border-color: color-mix(in srgb, var(--product-accent) 38%, var(--border));
  }

  .product-card:hover {
    border-color: color-mix(in srgb, var(--product-accent) 50%, var(--border));
    box-shadow: 0 18px 46px rgba(9, 18, 39, 0.11);
    transform: translateY(-2px);
  }

  .product-glyph {
    background:
      linear-gradient(135deg, var(--product-accent), color-mix(in srgb, var(--product-accent) 52%, var(--project-cyan)));
    border-radius: 8px;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.34);
    display: block;
    height: 2.4rem;
    margin-bottom: 1.2rem;
    position: relative;
    width: 2.4rem;
  }

  .product-glyph::after {
    border: 2px solid rgba(255, 255, 255, 0.82);
    border-left: 0;
    border-radius: 0 5px 5px 0;
    content: "";
    height: 0.9rem;
    left: 0.76rem;
    position: absolute;
    top: 0.62rem;
    width: 0.9rem;
  }

  .product-logo {
    border-radius: 8px;
    display: block;
    height: 2.4rem;
    margin-bottom: 1.2rem;
    object-fit: contain;
    width: 2.4rem;
  }

  .product-card-head {
    align-items: flex-start;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 0.75rem;
    justify-content: space-between;
    margin-bottom: 0.15rem;
  }

  .product-card-head h3 {
    min-width: 0;
  }

  .product-card-head .status {
    flex-shrink: 0;
    white-space: nowrap;
  }

  .purpose {
    color: var(--text);
    font-weight: 750;
    margin-bottom: 0;
  }

  .product-card a {
    color: var(--product-accent);
    font-weight: 800;
    margin-top: auto;
    padding-top: 1rem;
    text-decoration: none;
  }
</style>
