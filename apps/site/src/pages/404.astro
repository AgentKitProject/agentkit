---
import BaseLayout from '../layouts/BaseLayout.astro';
import { forgeUrl, roadmapUrl } from '../data/products';
---
<BaseLayout title="Page not found">
  <section class="section">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1>That page is not part of the kit.</h1>
      <p class="lead">Try the ecosystem home page or jump into the current Forge product.</p>
      <div class="button-row">
        <a class="button" href="/">Go home</a>
        <a class="button secondary" href={roadmapUrl}>View roadmap</a>
        <a class="button secondary" href={forgeUrl}>Explore Forge</a>
      </div>
    </div>
  </section>
</BaseLayout>
