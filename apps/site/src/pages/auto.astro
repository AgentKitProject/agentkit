---
import BaseLayout from '../layouts/BaseLayout.astro';
import { autoUrl } from '../data/products';
---
<BaseLayout
  title="AgentKitAuto"
  description="AgentKitAuto runs Agent Kits automatically on schedules, events, and triggers — hosted at auto.agentkitproject.com and fully self-hostable."
  theme="auto"
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Live</p>
      <h1>AgentKitAuto runs Agent Kits automatically.</h1>
      <p class="lead">
        Auto runs portable Agent Kits on demand, on a schedule, or from event and webhook triggers.
        It's hosted at auto.agentkitproject.com and fully self-hostable on your own infrastructure.
      </p>
      <div class="button-row">
        <a class="button" href={autoUrl}>Open AgentKitAuto</a>
        <a class="button secondary" href="/pricing">See pricing</a>
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="container grid three">
      <article class="card">
        <h3>Event-driven</h3>
        <p>
          Schedules, webhook and event triggers, external connections, and inbound messages (such as
          email-in or chat platforms) can start runs, with approvals handled in chat.
        </p>
      </article>
      <article class="card">
        <h3>Explicit opt-in</h3>
        <p>Auto never runs background operations without your permission — every automation is something you set up and enable.</p>
      </article>
      <article class="card">
        <h3>Self-hosted</h3>
        <p>Run the same codebase on your own infrastructure for full control over data and execution.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container content-panel">
      <p>
        Pricing is pay-for-compute: $0.01 per run plus $0.01 per active minute, with a one-time 60
        free active minutes for new accounts. Model tokens are billed at cost, or you can bring your
        own provider key. See <a href="/pricing">pricing</a> for details.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .section:first-child {
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--auto) 12%, transparent), transparent 34rem),
      transparent;
  }
</style>
