---
import BaseLayout from '../layouts/BaseLayout.astro';
import { webForgeUrl, githubOrgUrl } from '../data/products';
---
<BaseLayout
  title="AgentKitForge"
  description="AgentKitForge builds, edits, runs, packages, exports, and installs portable Agent Kits — in your browser or from the agentkitforge CLI."
  theme="forge"
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Current product</p>
      <h1>AgentKitForge builds and runs portable Agent Kits.</h1>
      <p class="lead">
        AgentKitForge is the app for building, editing, and running Agent Kits, then packaging,
        exporting, and installing them where they belong. Use it in your browser, or do the same
        local-first work headless with the <code>agentkitforge</code> CLI — both run the same
        open-source core engine.
      </p>
      <div class="button-row">
        <a class="button" href={webForgeUrl}>Open Forge</a>
        <a class="button secondary" href="/docs/web-forge/">Read Forge docs</a>
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="container grid three">
      <article class="card">
        <h3>Build and edit</h3>
        <p>Create kits with prepared prompts, skills, policies, templates, examples, and context.</p>
      </article>
      <article class="card">
        <h3>Run it</h3>
        <p>Use kits with your selected provider, collect required inputs, and generate outputs — in the browser or from the CLI.</p>
      </article>
      <article class="card">
        <h3>Package and install</h3>
        <p>Package <code>.agentkit.zip</code> files, export portable Markdown bundles, and install kits into supported agent tools.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container grid two">
      <div>
        <p class="eyebrow">Open source</p>
        <h2>Forge is open-core, and self-hostable.</h2>
      </div>
      <div class="content-panel">
        <p>
          The core engine and CLI are open source, and Forge (the web app) can be run on your own
          cluster alongside Market, Auto, and Profile — see <a href="/docs/self-hosting/">Self-hosting</a>.
        </p>
        <p><a href={githubOrgUrl}>View the AgentKitProject GitHub organization</a></p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section:first-child {
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--forge) 13%, transparent), transparent 34rem),
      transparent;
  }
</style>
