---
import ProductCard from '../components/ProductCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { githubOrgUrl, marketUrl, products, profileUrl, webForgeUrl } from '../data/products';

const flow = [
  ['Build & Run', 'var(--forge)', 'Create and run portable Agent Kits in AgentKitForge — in your browser or from the CLI — using prompts, skills, policies, templates, examples, and context.'],
  ['Share & Browse', 'var(--market)', 'Publish, discover, and download validated kits through AgentKitMarket — with organizations, private catalogs, and paid kits.'],
  ['Schedule & Automate', 'var(--auto)', 'Schedule and trigger trusted kits with AgentKitAuto on demand, on a schedule, or from webhooks — hosted or self-hosted.']
];
---
<BaseLayout title="AgentKitProject">
  <section class="section hero">
    <div class="container hero-inner">
      <div class="hero-logo" aria-label="AgentKitProject">
        <span class="hero-logo__mark" aria-hidden="true"></span>
        <span class="hero-logo__word">AgentKitProject</span>
      </div>
      <p class="eyebrow">Portable Agent Kit ecosystem</p>
      <h1>Create, share, and automate Agent Kits.</h1>
      <p class="lead">
        AgentKitProject is the ecosystem for repeatable AI work: build Agent Kits locally
        or in the browser, share and sell them through a validated catalog, and automate
        them across schedules, events, and workflows.
      </p>
      <div class="button-row">
        <a class="button" href={webForgeUrl}>Open Forge</a>
        <a class="button secondary" href={marketUrl}>Browse Market</a>
        <a class="button secondary" href={profileUrl}>Sign in</a>
      </div>
      <div class="ecosystem-strip" aria-label="AgentKitProject ecosystem flow">
        <span class="forge">AgentKitForge</span>
        <b style="--strip-accent: #5b4cf0;">Build &amp; Run</b>
        <span class="market">AgentKitMarket</span>
        <b style="--strip-accent: #0fb3d1;">Share &amp; Browse</b>
        <span class="auto">AgentKitAuto</span>
        <b style="--strip-accent: #16a34a;">Schedule &amp; Automate</b>
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="container">
      <p class="eyebrow">Products</p>
      <h2>One ecosystem, three focused layers.</h2>
      <div class="grid three product-grid">
        {products.map((product) => <ProductCard {...product} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Flow</p>
      <h2>Build & Run -> Share & Browse -> Schedule & Automate</h2>
      <div class="flow-grid">
        {flow.map(([title, accent, body], index) => (
          <article class="flow-step" style={`--flow-accent: ${accent};`}>
            <span>{index + 1}</span>
            <h3>{title}</h3>
            <p>{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="container grid two">
      <div>
        <p class="eyebrow">Open foundation</p>
        <h2>Portable kits should not be trapped in one app.</h2>
      </div>
      <div class="content-panel">
        <p>
          AgentKitProject is designed around portable kit artifacts and open-source core tooling.
          Forge, Market, and Auto are separate, independently usable ecosystem
          layers — not hidden backend features — and the core engine and CLI are open source.
        </p>
        <p><a href={githubOrgUrl}>Follow the project on GitHub</a></p>
      </div>
    </div>
  </section>

  <section class="section tight self-host-section">
    <div class="container self-host-inner">
      <div class="self-host-badge">Self-hostable</div>
      <h2 class="self-host-heading">Run AgentKitProject on your own infrastructure.</h2>
      <p class="self-host-body">
        AgentKitProject is designed to be self-hosted: local-first, open ecosystem, no vendor
        lock-in. Forge, Market, and Auto can all be self-hosted today — the same open-core
        codebase, running on your own infrastructure, with no cost to us.
      </p>
      <a class="button self-host-cta" href="/docs/self-hosting/">
        Self-host overview &rarr;
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-top: 4.5rem;
  }

  .hero-inner {
    min-height: min(720px, calc(100vh - 4.6rem));
  }

  /* Brand lockup: rounded icon chip + text wordmark. The wordmark is real text,
     so it recolors with the theme (the old wordmark image was a white-background
     SVG that showed a white box in dark mode). */
  .hero-logo {
    align-items: center;
    display: inline-flex;
    gap: 0.7rem;
    margin-bottom: 1.5rem;
  }

  .hero-logo__mark {
    background: url('/brand/agentkitproject-badge-light.svg') center / contain no-repeat;
    border: 1px solid rgba(91, 76, 240, 0.28);
    border-radius: 14px;
    box-shadow: 0 2px 10px rgba(9, 18, 39, 0.16);
    display: block;
    height: clamp(3rem, 7vw, 4rem);
    width: clamp(3rem, 7vw, 4rem);
  }

  /* Dark mode: the dark-native mark sits directly on the dark background — no
     tile/border/shadow, and a touch larger since it has no badge padding. */
  :global(html[data-theme="dark"]) .hero-logo__mark {
    background-image: url('/brand/agentkitproject-mark-dark.svg');
    border: none;
    border-radius: 0;
    box-shadow: none;
    height: clamp(3.4rem, 7.6vw, 4.5rem);
    width: clamp(3.4rem, 7.6vw, 4.5rem);
  }

  .hero-logo__word {
    color: var(--text);
    font-size: clamp(1.9rem, 5vw, 2.75rem);
    font-weight: 850;
    letter-spacing: -0.02em;
  }

  /* Ecosystem flow strip: uses theme surface tokens so it is a LIGHT card in
     light mode and a dark card in dark mode (previously hard-coded navy, so it
     stayed dark in light mode). */
  .ecosystem-strip {
    align-items: center;
    background: var(--muted-surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    box-shadow: var(--shadow);
    display: grid;
    gap: 0.65rem;
    grid-template-columns: repeat(6, auto);
    margin-top: 4rem;
    max-width: 890px;
    padding: 1rem;
  }

  .ecosystem-strip span {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    font-weight: 850;
    padding: 0.85rem 1rem;
  }

  .ecosystem-strip span.forge {
    box-shadow: inset 3px 0 0 var(--forge);
  }

  .ecosystem-strip span.market {
    box-shadow: inset 3px 0 0 var(--market);
  }

  .ecosystem-strip span.auto {
    box-shadow: inset 3px 0 0 var(--auto);
  }

  .ecosystem-strip b {
    color: var(--strip-accent);
    font-size: 0.82rem;
    text-transform: uppercase;
  }

  .product-grid {
    margin-top: 2rem;
  }

  .flow-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 2rem;
  }

  .flow-step {
    background: var(--surface);
    border: 1px solid color-mix(in srgb, var(--flow-accent, var(--project-blue)) 16%, var(--border));
    border-left: 3px solid var(--flow-accent, var(--project-blue));
    border-radius: 8px;
    box-shadow: var(--shadow);
    padding: 0.35rem 1rem 0.35rem 1.25rem;
  }

  .flow-step span {
    color: var(--flow-accent, var(--project-cyan));
    display: block;
    font-size: 0.9rem;
    font-weight: 900;
    margin-bottom: 0.5rem;
  }

  .self-host-section {
    border-top: 1px solid var(--border);
  }

  .self-host-inner {
    align-items: flex-start;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 680px;
  }

  .self-host-badge {
    background: color-mix(in srgb, var(--auto) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--auto) 30%, transparent);
    border-radius: 999px;
    color: var(--auto);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 0.25rem 0.75rem;
    text-transform: uppercase;
  }

  .self-host-heading {
    margin: 0;
  }

  .self-host-body {
    color: var(--muted);
    margin: 0;
  }

  .self-host-cta {
    margin-top: 0.25rem;
  }

  @media (max-width: 860px) {
    .hero-inner {
      min-height: auto;
    }

    .ecosystem-strip,
    .flow-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
