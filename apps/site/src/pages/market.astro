---
import BaseLayout from '../layouts/BaseLayout.astro';
import { forgeUrl, marketUrl } from '../data/products';
---
<BaseLayout
  title="AgentKitMarket"
  description="AgentKitMarket is the live public catalog for Agent Kits: browse, publish, and download, with organizations, private team catalogs, and paid kits."
  theme="market"
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Live catalog</p>
      <h1>AgentKitMarket helps people discover and distribute Agent Kits.</h1>
      <p class="lead">
        Market is the live public catalog and sharing foundation for Agent Kits: browse, publish,
        and download, with every submission going through validation and admin review before it's
        published. Organizations and team roles, private team catalogs, paid kits, and favorites
        are all available today. Self-hostable on your own infrastructure.
      </p>
      <div class="button-row">
        <a class="button" href={marketUrl}>Open AgentKitMarket</a>
        <a class="button secondary" href={forgeUrl}>Build kits in Forge</a>
        <a class="button secondary" href="/pricing">See pricing</a>
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="container grid two">
      <article class="content-panel">
        <h2>Public sharing, reviewed before it's live.</h2>
        <p>
          Discoverable public kits, signed-in submission and download flows, and admin
          validation/review/publish before anything reaches the catalog — plus clean public
          profile display for publishers.
        </p>
      </article>
      <article class="content-panel">
        <h2>Organizations, private catalogs, and paid kits.</h2>
        <p>
          Teams can create an organization, assign member roles, and keep kits visible only to
          their org. Sellers can list premium kits priced per run instead of giving them away for
          free. See <a href="/pricing">pricing</a> for how the 6% platform commission works.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .section:first-child {
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--market) 14%, transparent), transparent 34rem),
      transparent;
  }
</style>
