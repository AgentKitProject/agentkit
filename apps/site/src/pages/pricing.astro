---
import BaseLayout from '../layouts/BaseLayout.astro';
import { autoUrl, forgeUrl, marketUrl, profileUrl, githubOrgUrl } from '../data/products';
---
<BaseLayout
  title="Pricing"
  description="Pricing across the AgentKitProject ecosystem: free to build, publish, and browse; usage billed only at cost; and completely free to self-host."
>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Pricing</p>
      <h1>Free to build. Usage billed at cost.</h1>
      <p class="lead">
        Building, publishing, and browsing Agent Kits is free. You pay only to run kits on managed
        AI, and only at cost &mdash; no markup &mdash; or bring your own provider key and pay the
        provider directly. You can also self-host the entire stack and pay us nothing.
      </p>
      <div class="button-row">
        <a class="button" href={marketUrl}>Open AgentKitMarket</a>
        <a class="button secondary" href={forgeUrl}>Open AgentKitForge</a>
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="container">
      <p class="eyebrow">By app</p>
      <h2>What each app costs.</h2>
      <div class="grid two" style="margin-top: 2rem;">
        <article class="card">
          <h3>AgentKitForge &mdash; free</h3>
          <p>
            Building, validating, packaging, exporting, importing, and publishing kits cost nothing.
            Local kit work in the browser or the <code>agentkitforge</code> CLI needs no account. The
            only usage cost is running or chatting with a kit on managed AI, billed at the underlying
            model price with no markup &mdash; or bring your own provider key and pay the provider
            directly.
          </p>
        </article>
        <article class="card">
          <h3>AgentKitMarket &mdash; free to browse, publish, and download</h3>
          <p>
            Listing and downloading free kits cost nothing. Sellers may instead list a premium kit
            priced per run: the platform keeps a 6% commission and the seller keeps 94%. A premium
            kit runs on AgentKitAuto &mdash; its files are never handed to the buyer &mdash; and each
            run charges the buyer's prepaid balance.
          </p>
        </article>
        <article class="card">
          <h3>AgentKitAuto &mdash; pay only for compute</h3>
          <p>
            $0.01 per run plus $0.01 per active minute. New accounts get their first 60 active
            minutes free &mdash; a one-time trial, not a monthly allowance. Model tokens are billed at
            cost with no markup, or bring your own provider key and pay the provider directly. Pay via
            managed credits or your own key; no commitment.
          </p>
        </article>
        <article class="card">
          <h3>AgentKitProfile &mdash; free</h3>
          <p>
            Shared identity, public profile pages, and organizations. No cost.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section tight">
    <div class="container">
      <article class="content-panel">
        <p class="eyebrow">Self-hosting</p>
        <h2>Self-hosting is completely free.</h2>
        <p>
          Every app is open-core. You can run the entire stack &mdash; Forge, Market, Auto, and
          Profile &mdash; on your own infrastructure and pay us nothing. You pay only your own AI
          provider and hosting. Helm charts and a self-hosting guide are published, and versioned
          container images are released for self-hosters to pin.
        </p>
        <div class="button-row">
          <a class="button" href={githubOrgUrl}>View on GitHub</a>
        </div>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="content-panel">
        <h2>Start free.</h2>
        <p>
          Build and publish at no cost, run kits at cost when you need to, or self-host the whole
          stack yourself.
        </p>
        <div class="button-row">
          <a class="button" href={marketUrl}>Explore AgentKitMarket</a>
          <a class="button secondary" href={autoUrl}>See AgentKitAuto</a>
          <a class="button secondary" href={profileUrl}>See AgentKitProfile</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section:first-child {
    background:
      linear-gradient(135deg, color-mix(in srgb, var(--theme-accent) 13%, transparent), transparent 34rem),
      transparent;
  }
</style>
