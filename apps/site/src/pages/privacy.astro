---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Privacy Policy"
  description="AgentKitProject Privacy Policy."
>
  <section class="section">
    <div class="container">
      <div class="template-notice">
        <strong>Template — not legal advice.</strong> This is a placeholder template. Review with qualified legal counsel before publishing.
      </div>
      <p class="eyebrow">Legal</p>
      <h1>Privacy Policy</h1>
      <p class="lead">Last updated: June 2026</p>

      <div class="legal-body">
        <h2>1. Information We Collect</h2>
        <p>We collect information you provide directly to us, such as when you create an account, submit an Agent Kit, or contact us at <a href="mailto:hello@agentkit-project.com">hello@agentkit-project.com</a>.</p>

        <h2>2. How We Use Information</h2>
        <p>We use the information we collect to provide, maintain, and improve our services, including AgentKitForge, AgentKitMarket, and AgentKitProfile.</p>

        <h2>3. Information Sharing</h2>
        <p>We do not sell your personal information. We may share information with service providers who assist us in operating our services.</p>

        <h2>4. Data Retention</h2>
        <p>We retain information for as long as necessary to provide our services and comply with legal obligations.</p>

        <h2>5. Security</h2>
        <p>We implement reasonable security measures to protect your information. To report a security concern, please see our <a href="/.well-known/security.txt">security policy</a>.</p>

        <h2>6. Contact</h2>
        <p>For privacy questions, contact us at <a href="mailto:hello@agentkit-project.com">hello@agentkit-project.com</a>.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .template-notice {
    background: #fef9c3;
    border: 1px solid #fde047;
    border-radius: 8px;
    margin-bottom: 2rem;
    padding: 1rem 1.25rem;
    color: #713f12;
  }
  .legal-body h2 {
    font-size: 1.2rem;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .legal-body p {
    margin-bottom: 1rem;
  }
</style>
